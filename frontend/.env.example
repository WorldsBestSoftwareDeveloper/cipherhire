# CipherHire Frontend — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Deployed Contract Addresses (Sepolia) ──────────────────────────────────────
# These are set after running: cd contracts && npm run deploy:sepolia
NEXT_PUBLIC_TASK_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BID_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MATCHING_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000

# ── Network ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SEPOLIA_RPC=https://rpc.sepolia.org
# Or use Alchemy/Infura for better reliability:
# NEXT_PUBLIC_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── WalletConnect ──────────────────────────────────────────────────────────────
# Get a free project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
