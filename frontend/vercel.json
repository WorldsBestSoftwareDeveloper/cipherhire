{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_TASK_MANAGER_ADDRESS": "@task_manager_address",
    "NEXT_PUBLIC_BID_MANAGER_ADDRESS": "@bid_manager_address",
    "NEXT_PUBLIC_MATCHING_ENGINE_ADDRESS": "@matching_engine_address",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID": "@walletconnect_project_id",
    "NEXT_PUBLIC_SEPOLIA_RPC": "@sepolia_rpc_url"
  }
}
